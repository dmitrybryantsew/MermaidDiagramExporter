<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:settings="clr-namespace:MermaidDiagramExporter.Gui.Settings"
        x:Class="MermaidDiagramExporter.Gui.Settings.SettingsWindow"
        Title="Project Settings"
        Width="520"
        Height="600"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Border Padding="20">
    <Grid RowDefinitions="*,Auto">
      <ScrollViewer Grid.Row="0">
        <StackPanel Spacing="16">
          <!-- Project Identification -->
          <TextBlock Text="Project" FontWeight="Bold" FontSize="16" />
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Grid.Column="0" Text="Source Folder:" VerticalAlignment="Center" Width="120" />
            <TextBlock Grid.Column="1" x:Name="SourceFolderText" TextWrapping="Wrap" Opacity="0.7" />
          </Grid>

          <!-- Cache Settings -->
          <TextBlock Text="Cache" FontWeight="Bold" FontSize="16" Margin="0,8,0,0" />
          <CheckBox x:Name="AutoSaveCacheCheck" Content="Auto-save relationship cache after scan" />
          <CheckBox x:Name="AutoSaveSourceBundleCheck" Content="Auto-save source bundle after scan" />
          <CheckBox x:Name="PromptLoadCacheCheck" Content="Prompt to load from cache when reopening project" />
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Grid.Column="0" Text="On source change:" VerticalAlignment="Center" Width="120" />
            <ComboBox x:Name="CacheInvalidationCombo" Grid.Column="1" Width="260" HorizontalAlignment="Left">
              <ComboBoxItem Content="Warn and prompt to rescan" />
              <ComboBoxItem Content="Automatically rescan" />
              <ComboBoxItem Content="Ignore (use cache regardless)" />
            </ComboBox>
          </Grid>
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Grid.Column="0" Text="Cache folder:" VerticalAlignment="Center" Width="120" />
            <TextBox Grid.Column="1" x:Name="CacheFolderText" PlaceholderText="(default)" IsReadOnly="True" />
            <Button Grid.Column="2" x:Name="BrowseCacheButton" Content="Browse..." Margin="8,0,0,0" />
          </Grid>
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Grid.Column="0" Text="Bundle folder:" VerticalAlignment="Center" Width="120" />
            <TextBox Grid.Column="1" x:Name="BundleFolderText" PlaceholderText="(default)" IsReadOnly="True" />
            <Button Grid.Column="2" x:Name="BrowseBundleButton" Content="Browse..." Margin="8,0,0,0" />
          </Grid>

          <!-- Search Settings -->
          <TextBlock Text="Search" FontWeight="Bold" FontSize="16" Margin="0,8,0,0" />
          <CheckBox x:Name="SearchCaseSensitiveCheck" Content="Case-sensitive search" />
          <CheckBox x:Name="SearchIncludeMembersCheck" Content="Include member names in semantic search" />
          <CheckBox x:Name="AutoFocusSearchCheck" Content="Auto-focus canvas on search results" />

          <!-- Stereotype Settings -->
          <TextBlock Text="Stereotypes" FontWeight="Bold" FontSize="16" Margin="0,8,0,0" />
          <CheckBox x:Name="ApplyCustomStereotypesCheck" Content="Apply custom stereotype rules" />
          <Border BorderBrush="#3A4250" BorderThickness="1" CornerRadius="4" Padding="8">
            <Grid RowDefinitions="Auto,*">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Rules" FontWeight="Bold" Margin="0,0,0,4" />
                <Button Grid.Column="1" x:Name="AddStereotypeRuleButton" Content="+ Add" Padding="8,2" />
              </Grid>
              <ListBox Grid.Row="1" x:Name="StereotypeRulesList" Height="160" BorderThickness="0" Background="Transparent">
                <ListBox.DataTemplates>
                  <DataTemplate DataType="settings:StereotypeRule">
                    <StackPanel>
                      <Grid ColumnDefinitions="*,100,80,Auto">
                        <TextBox Grid.Column="0" Text="{Binding Pattern}" PlaceholderText="Regex pattern" Margin="0,0,4,0" />
                        <TextBox Grid.Column="1" Text="{Binding Label}" PlaceholderText="Label" Margin="0,0,4,0" />
                        <TextBox Grid.Column="2" Text="{Binding ColorHex}" PlaceholderText="#RRGGBB" Margin="0,0,4,0" />
                        <Button Grid.Column="3" Content="x" Tag="{Binding}" Click="OnRemoveStereotypeRule" />
                      </Grid>
                      <TextBlock x:Name="PatternErrorText" FontSize="10" Foreground="#FF6040" Margin="0,2,0,0" IsVisible="False" TextWrapping="Wrap" />
                    </StackPanel>
                  </DataTemplate>
                </ListBox.DataTemplates>
              </ListBox>
            </Grid>
          </Border>

          <!-- Stereotype validation errors -->
          <TextBlock x:Name="StereotypeErrorText" FontSize="11" Foreground="#FF6040" Margin="0,4,0,0" IsVisible="False" TextWrapping="Wrap" />

          <!-- Canvas Settings -->
          <TextBlock Text="Canvas" FontWeight="Bold" FontSize="16" Margin="0,8,0,0" />
          <CheckBox x:Name="PersistLayoutCheck" Content="Persist manual layout positions" />
          <CheckBox x:Name="EnableDraggingCheck" Content="Enable node drag-to-reposition" />
          <CheckBox x:Name="ShowMinimapCheck" Content="Show minimap" />

          <!-- Keyboard Shortcuts -->
          <TextBlock Text="Design Mode Shortcuts" FontWeight="Bold" FontSize="16" Margin="0,16,0,0" />
          <TextBlock Text="Press a key in the text field to rebind. Leave blank for default." FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,8" />
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="140,60,140,60" MaxHeight="200">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Select" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="0" Grid.Column="1" x:Name="ShortcutSelect" Width="50" FontSize="12" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Inheritance" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="0" Grid.Column="3" x:Name="ShortcutEdgeInheritance" Width="50" FontSize="12" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Class" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="1" Grid.Column="1" x:Name="ShortcutClass" Width="50" FontSize="12" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Implements" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="1" Grid.Column="3" x:Name="ShortcutEdgeImplements" Width="50" FontSize="12" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Interface" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="2" Grid.Column="1" x:Name="ShortcutInterface" Width="50" FontSize="12" />
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Association" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="2" Grid.Column="3" x:Name="ShortcutEdgeAssociation" Width="50" FontSize="12" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Enum" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="3" Grid.Column="1" x:Name="ShortcutEnum" Width="50" FontSize="12" />
            <TextBlock Grid.Row="3" Grid.Column="2" Text="Dependency" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="3" Grid.Column="3" x:Name="ShortcutEdgeDependency" Width="50" FontSize="12" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Struct" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="4" Grid.Column="1" x:Name="ShortcutStruct" Width="50" FontSize="12" />
            <TextBlock Grid.Row="4" Grid.Column="2" Text="Aggregation" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="4" Grid.Column="3" x:Name="ShortcutEdgeAggregation" Width="50" FontSize="12" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Abstract" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="5" Grid.Column="1" x:Name="ShortcutAbstractClass" Width="50" FontSize="12" />
            <TextBlock Grid.Row="5" Grid.Column="2" Text="Composition" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="5" Grid.Column="3" x:Name="ShortcutEdgeComposition" Width="50" FontSize="12" />

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Static" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="6" Grid.Column="1" x:Name="ShortcutStaticClass" Width="50" FontSize="12" />

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Namespace" VerticalAlignment="Center" FontSize="12" />
            <TextBox  Grid.Row="7" Grid.Column="1" x:Name="ShortcutNamespace" Width="50" FontSize="12" />
          </Grid>
          <Button x:Name="ResetShortcutsButton" Content="Reset to Defaults" Margin="0,8,0,0" HorizontalAlignment="Right" />

          <!-- Experimental Layout Engine -->
          <TextBlock Text="Experimental" FontWeight="Bold" FontSize="16" Margin="0,16,0,0" Foreground="#FFA040" />
          <CheckBox x:Name="UseMsaglEngineCheck" Content="Use MSAGL layout engine (prototype)" />
          <TextBlock Text="Backed by Microsoft Automatic Graph Layout (Sugiyama framework, same family as Mermaid's dagre). Native cluster containment + orthogonal routing. Takes precedence over the compound engine when on." FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="20,2,0,0" />
          <CheckBox x:Name="SeparateAppAndTestsCheck" Content="Separate app / test classes (MSAGL only)" Margin="0,8,0,0" />
          <TextBlock Text="Creates two top-level clusters — Application and Tests — based on namespace patterns (*.Tests, *.Test). Produces a left/right visual separation." FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="20,2,0,0" />
          <CheckBox x:Name="PartitionByFirstLevelNsCheck" Content="Partition by first-level namespace (MSAGL only)" Margin="0,8,0,0" />
          <TextBlock Text="Auto-detects the topmost common namespace prefix and creates a synthetic cluster per distinct first-level sub-namespace (e.g. PFE.Data, PFE.Systems, PFE.Tests). Mutually exclusive with the app/tests toggle above." FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="20,2,0,0" />
          <CheckBox x:Name="UseCompoundEngineCheck" Content="Use compound layout engine (experimental)" Margin="0,8,0,0" />
          <TextBlock Text="Ranks all nodes globally with cluster-contiguity constraints. Ignored when MSAGL is enabled. Requires re-scan to take effect." FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="20,2,0,0" />

          <!-- Edge Styles -->
          <TextBlock Text="Edge Styles" FontWeight="Bold" FontSize="16" Margin="0,16,0,0" />
          <TextBlock Text="Per-kind color (hex) and arrowhead shape. UML defaults: inheritance/implements = hollow triangle, association = solid arrow." FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,8" />

          <Grid ColumnDefinitions="Auto,140,160" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,0">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Inheritance" VerticalAlignment="Center" Margin="0,0,12,4" />
            <TextBox  Grid.Row="0" Grid.Column="1" x:Name="InheritanceColorText" Watermark="#RRGGBB" Margin="0,0,8,4" />
            <ComboBox  Grid.Row="0" Grid.Column="2" x:Name="InheritanceArrowCombo" Margin="0,0,0,4">
              <ComboBoxItem Content="Solid Arrow" />
              <ComboBoxItem Content="Hollow Triangle" />
              <ComboBoxItem Content="Hollow Diamond" />
              <ComboBoxItem Content="Filled Diamond" />
              <ComboBoxItem Content="None" />
            </ComboBox>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Implements" VerticalAlignment="Center" Margin="0,0,12,4" />
            <TextBox  Grid.Row="1" Grid.Column="1" x:Name="ImplementsColorText" Watermark="#RRGGBB" Margin="0,0,8,4" />
            <ComboBox  Grid.Row="1" Grid.Column="2" x:Name="ImplementsArrowCombo" Margin="0,0,0,4">
              <ComboBoxItem Content="Solid Arrow" />
              <ComboBoxItem Content="Hollow Triangle" />
              <ComboBoxItem Content="Hollow Diamond" />
              <ComboBoxItem Content="Filled Diamond" />
              <ComboBoxItem Content="None" />
            </ComboBox>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Association" VerticalAlignment="Center" Margin="0,0,12,4" />
            <TextBox  Grid.Row="2" Grid.Column="1" x:Name="AssociationColorText" Watermark="#RRGGBB" Margin="0,0,8,4" />
            <ComboBox  Grid.Row="2" Grid.Column="2" x:Name="AssociationArrowCombo" Margin="0,0,0,4">
              <ComboBoxItem Content="Solid Arrow" />
              <ComboBoxItem Content="Hollow Triangle" />
              <ComboBoxItem Content="Hollow Diamond" />
              <ComboBoxItem Content="Filled Diamond" />
              <ComboBoxItem Content="None" />
            </ComboBox>
          </Grid>
        </StackPanel>
      </ScrollViewer>

      <!-- Buttons -->
      <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
        <Button x:Name="ResetDefaultsButton" Content="Reset Defaults" />
        <Button x:Name="CancelButton" Content="Cancel" />
        <Button x:Name="SaveButton" Content="Save" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
