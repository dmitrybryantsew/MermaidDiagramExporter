<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MermaidDiagramExporter.Gui"
        xmlns:search="clr-namespace:MermaidDiagramExporter.Gui.Search"
        xmlns:matrix="clr-namespace:MermaidDiagramExporter.Gui.Matrix"
        xmlns:design="clr-namespace:MermaidDiagramExporter.Gui.Design"
        xmlns:core="clr-namespace:MermaidDiagramExporter.Core"
        x:Class="MermaidDiagramExporter.Gui.MainWindow"
        Title="Mermaid Diagram Exporter" Width="1400" Height="900"
        WindowState="Maximized">
  <Grid ColumnDefinitions="320,1,*,1,300" RowDefinitions="*,Auto">
    <!-- Sidebar -->
    <ScrollViewer Grid.Column="0" Grid.Row="0" Background="#F0F0F0">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        <!-- Mode toggle (M0 scaffold) -->
        <Grid Grid.Row="0" Margin="8,8,8,4" ColumnDefinitions="*,*">
          <Button Grid.Column="0" x:Name="AnalyzeModeButton" Content="Analyze" Click="OnAnalyzeModeClick"
                  Background="#4CAF50" Foreground="White" Margin="0,0,2,0"/>
          <Button Grid.Column="1" x:Name="DesignModeButton" Content="Design" Click="OnDesignModeClick"
                  Background="#3A4250" Foreground="White" Margin="2,0,0,0"/>
        </Grid>

        <!-- Analyze Mode controls -->
        <StackPanel Grid.Row="1" x:Name="AnalyzeModePanel">
          <!-- Folder picker -->
          <StackPanel Margin="8">
            <TextBlock Text="Source Folder" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="FolderTextBox" PlaceholderText="Select folder..." IsReadOnly="True" Margin="0,0,0,4" Foreground="White"/>
            <Grid ColumnDefinitions="*,*">
              <Button Grid.Column="0" Content="Browse..." Click="OnBrowse" Margin="0,0,2,0" Foreground="White"/>
              <Button Grid.Column="1" Content="Scan" Click="OnScan" Margin="2,0,0,0" Background="#4CAF50" Foreground="White"/>
            </Grid>
          </StackPanel>

          <!-- Navigation buttons -->
          <WrapPanel Margin="8,0,8,4" Orientation="Horizontal" ItemWidth="NaN">
            <Button x:Name="BackButton" Content="← Back" Click="OnBack" IsEnabled="False" MinWidth="70" Foreground="White" Margin="0,0,4,4"/>
            <Button x:Name="ForwardButton" Content="Forward →" Click="OnForward" IsEnabled="False" MinWidth="70" Foreground="White" Margin="0,0,4,4"/>
            <Button x:Name="ResetButton" Content="Reset" Click="OnReset" IsEnabled="False" MinWidth="50" Foreground="White" Margin="0,0,4,4"/>
            <Button x:Name="SettingsButton" Content="Settings" Click="OnOpenSettings" MinWidth="60" Foreground="White" Margin="0,0,4,4"/>
            <Button x:Name="ResetLayoutButton" Content="Reset Layout" Click="OnResetLayout" MinWidth="80" Foreground="White" Margin="0,0,4,4"/>
            <Button x:Name="MatrixButton" Content="Matrix" Click="OnToggleMatrix" MinWidth="60" Foreground="White" Margin="0,0,4,4"/>
          </WrapPanel>

          <!-- Focus controls -->
          <StackPanel Margin="8,0,8,4">
            <TextBlock Text="Focus Depth" FontWeight="Bold" Margin="0,0,0,4"/>
            <WrapPanel Orientation="Horizontal">
              <Button Content="D1" Click="OnFocusD1" MinWidth="50" Foreground="White" Margin="0,0,4,4"/>
              <Button Content="D2" Click="OnFocusD2" MinWidth="50" Foreground="White" Margin="0,0,4,4"/>
              <Button Content="D3" Click="OnFocusD3" MinWidth="50" Foreground="White" Margin="0,0,4,4"/>
            </WrapPanel>
            <TextBlock Text="Traversal" FontWeight="Bold" Margin="0,6,0,4"/>
            <ComboBox x:Name="TraversalComboBox" MinWidth="200" SelectionChanged="OnTraversalChanged" Foreground="White">
              <ComboBoxItem Content="Undirected" IsSelected="True"/>
              <ComboBoxItem Content="Outgoing"/>
              <ComboBoxItem Content="Incoming"/>
              <ComboBoxItem Content="All Visible"/>
            </ComboBox>
            <TextBlock Text="Seeds" FontWeight="Bold" Margin="0,6,0,4"/>
            <WrapPanel Orientation="Horizontal">
              <Button Content="Add Seed" Click="OnAddSeed" MinWidth="70" Foreground="White" Margin="0,0,4,4"/>
              <Button Content="Remove Seed" Click="OnRemoveSeed" MinWidth="80" Foreground="White" Margin="0,0,4,4"/>
              <Button Content="Clear" Click="OnClearSeeds" MinWidth="50" Foreground="White" Margin="0,0,4,4"/>
            </WrapPanel>
            <Button Content="Focus Current Selection" Click="OnFocusCurrent" Margin="0,4,0,0" Background="#2196F3" Foreground="White"/>
          </StackPanel>

          <!-- Edge filters -->
          <StackPanel Margin="8,0,8,4">
            <TextBlock Text="Edge Filters" FontWeight="Bold" Margin="0,0,0,4"/>
            <WrapPanel Orientation="Horizontal">
              <CheckBox x:Name="ShowInheritanceCheck" Content="Inheritance" IsChecked="True" Click="OnEdgeFilterChanged" Margin="0,0,8,0" Foreground="White"/>
              <CheckBox x:Name="ShowImplementsCheck" Content="Implements" IsChecked="True" Click="OnEdgeFilterChanged" Margin="0,0,8,0" Foreground="White"/>
              <CheckBox x:Name="ShowAssociationsCheck" Content="Associations" IsChecked="True" Click="OnEdgeFilterChanged" Foreground="White"/>
            </WrapPanel>
            <CheckBox x:Name="AutoRedrawCheck" Content="Auto-redraw edges on move (Ctrl+R = manual)" IsChecked="True" Click="OnAutoRedrawChanged" Margin="0,4,0,0" Foreground="White" FontSize="11"/>
          </StackPanel>

          <!-- Namespace Focus -->
          <StackPanel Margin="8,0,8,4">
            <TextBlock Text="Namespace Focus" FontWeight="Bold" Margin="0,0,0,4"/>
            <ComboBox x:Name="NamespaceFocusCombo" MinWidth="160" SelectionChanged="OnNamespaceFocusChanged" Margin="0,0,0,4" />
            <WrapPanel Orientation="Horizontal">
              <CheckBox x:Name="ShowConnectedNamespacesCheck" Content="Show connected" Click="OnNamespaceFocusToggleChanged" Margin="0,0,8,0" Foreground="White" FontSize="11"/>
            </WrapPanel>
            <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
              <Button Content="D1" Click="OnNamespaceFocusD1" MinWidth="40" Foreground="White" Margin="0,0,4,2" FontSize="11"/>
              <Button Content="D2" Click="OnNamespaceFocusD2" MinWidth="40" Foreground="White" Margin="0,0,4,2" FontSize="11"/>
              <Button Content="D3" Click="OnNamespaceFocusD3" MinWidth="40" Foreground="White" Margin="0,0,4,2" FontSize="11"/>
            </WrapPanel>
          </StackPanel>

          <!-- Search -->
          <StackPanel Margin="8,0,8,4">
            <TextBlock Text="Search" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="SearchTextBox" PlaceholderText="Type to highlight..." TextChanged="OnSearchTextChanged" Foreground="White"/>
          </StackPanel>

          <!-- Semantic Search Panel -->
          <search:SearchPanel x:Name="SymbolSearchPanel" />

          <!-- Design bridge -->
          <StackPanel Margin="8,0,8,4">
            <TextBlock Text="Design" FontWeight="Bold" Margin="0,0,0,4"/>
            <Button Content="Edit in Design Mode" Click="OnEditInDesignMode" MinWidth="140" Background="#FF9800" Foreground="White"/>
            <TextBlock Text="Convert scanned architecture to editable design" FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,4,0,0"/>
          </StackPanel>

          <!-- Class list -->
          <Grid Margin="8,0,8,0" RowDefinitions="Auto,*" MinHeight="150">
            <TextBlock Grid.Row="0" Text="Classes" FontWeight="Bold" Margin="0,0,0,4"/>
            <ListBox Grid.Row="1" x:Name="ClassListBox" SelectionChanged="OnClassSelected"/>
          </Grid>

          <!-- Stats -->
          <TextBlock x:Name="StatsText" Text="" Margin="8" Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Design Mode controls (W2) -->
        <StackPanel Grid.Row="2" x:Name="DesignModePanel" IsVisible="False">
          <!-- File operations -->
          <StackPanel Margin="8">
            <TextBlock Text="File" FontWeight="Bold" Margin="0,0,0,4"/>
            <WrapPanel Orientation="Horizontal">
              <Button Content="New" Click="OnDesignNew" MinWidth="60" Foreground="White" Margin="0,0,4,4"/>
              <Button Content="Open..." Click="OnDesignOpen" MinWidth="60" Foreground="White" Margin="0,0,4,4"/>
              <Button Content="Save" Click="OnDesignSave" MinWidth="60" Foreground="White" Margin="0,0,4,4"/>
              <Button Content="Save As..." Click="OnDesignSaveAs" MinWidth="80" Foreground="White" Margin="0,0,4,4"/>
              <Button Content="Settings" Click="OnOpenSettings" MinWidth="60" Foreground="White" Margin="0,0,4,4"/>
            </WrapPanel>
          </StackPanel>

          <!-- Editing tools -->
          <StackPanel Margin="8">
            <TextBlock Text="Edit" FontWeight="Bold" Margin="0,0,0,4"/>
            <WrapPanel Orientation="Horizontal">
              <Button Content="Undo" Click="OnDesignUndo" MinWidth="60" Foreground="White" Margin="0,0,4,4"/>
              <Button Content="Redo" Click="OnDesignRedo" MinWidth="60" Foreground="White" Margin="0,0,4,4"/>
            </WrapPanel>
          </StackPanel>

          <!-- Add tools -->
          <StackPanel Margin="8">
            <TextBlock Text="Add" FontWeight="Bold" Margin="0,0,0,4"/>
            <WrapPanel Orientation="Horizontal">
              <Button Content="Class" Click="OnDesignAddClass" MinWidth="60" Foreground="White" Margin="0,0,4,4"/>
              <Button x:Name="DesignConnectButton" Content="Connect" Click="OnDesignConnect" MinWidth="70" Foreground="White" Margin="0,0,4,4"/>
              <ComboBox x:Name="DesignEdgeCombo" SelectedIndex="0" SelectionChanged="OnDesignEdgeTypeSelected" MinWidth="80" Margin="0,0,4,4">
                <ComboBoxItem Content="Edge: Assoc"/>
                <ComboBoxItem Content="Edge: Inherit"/>
                <ComboBoxItem Content="Edge: Implmn"/>
                <ComboBoxItem Content="Edge: Depend"/>
                <ComboBoxItem Content="Edge: Aggreg"/>
                <ComboBoxItem Content="Edge: Compos"/>
              </ComboBox>
            </WrapPanel>
            <TextBlock Text="Tip: Select 2 classes, then click Connect. Or pick edge type, click source, click target." FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,4,0,0"/>
          </StackPanel>

          <!-- Export -->
          <StackPanel Margin="8">
            <TextBlock Text="Export" FontWeight="Bold" Margin="0,0,0,4"/>
            <WrapPanel Orientation="Horizontal">
              <Button Content="Mermaid" Click="OnDesignExportMermaid" MinWidth="70" Foreground="White" Margin="0,0,4,4"/>
              <Button Content="C# Stub" Click="OnDesignExportCSharp" MinWidth="70" Foreground="White" Margin="0,0,4,4"/>
              <Button Content="JSON" Click="OnDesignExportJson" MinWidth="60" Foreground="White" Margin="0,0,4,4"/>
            </WrapPanel>
          </StackPanel>

          <!-- Help -->
          <StackPanel Margin="8">
            <TextBlock Text="Tips" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="• Press C to arm Class tool, click canvas" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
            <TextBlock Text="• V = Select, drag to move, marquee" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
            <TextBlock Text="• Drag class header to move" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
            <TextBlock Text="• Drag corner to resize" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
            <TextBlock Text="• Double-click class name to rename" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
            <TextBlock Text="• Delete key removes selection" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
            <TextBlock Text="• Escape cancels / clears selection" FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,8"/>
          </StackPanel>
        </StackPanel>
      </Grid>
    </ScrollViewer>

    <!-- Left Splitter -->
    <GridSplitter Grid.Column="1" Grid.Row="0" Background="#D0D0D0" Width="1"/>

    <!-- Graph canvas -->
    <Grid Grid.Column="2" Grid.Row="0">
      <local:GraphCanvas x:Name="GraphCanvasView" MinWidth="100" MinHeight="100"/>
      <!-- Inline edit TextBox overlay (Design Mode only, positioned on top of canvas) -->
      <TextBox x:Name="InlineEditTextBox"
               IsVisible="False"
               Background="#2A2E34" Foreground="White"
               BorderBrush="#FFA040" BorderThickness="2"
               Padding="4,2"
               MinWidth="120"
               FontSize="13"/>
      <!-- Minimap overlay -->
      <local:MinimapControl x:Name="MinimapView"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="12"
                            IsVisible="False"/>
      <!-- Matrix overlay -->
      <matrix:NamespaceMatrixView x:Name="MatrixView"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  IsVisible="False"/>
      <!-- Zoom controls overlay -->
      <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Spacing="4">
        <Button Content="Fit" Click="OnFit" MinWidth="40" Background="#3A4250" Foreground="White"/>
        <Button Content="+" Click="OnZoomIn" MinWidth="40" Background="#3A4250" Foreground="White"/>
        <Button Content="−" Click="OnZoomOut" MinWidth="40" Background="#3A4250" Foreground="White"/>
      </StackPanel>
      <!-- Export buttons overlay (bottom-left, to avoid overlapping the minimap at bottom-right) -->
      <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8" Spacing="4" ZIndex="10">
        <Button Content="Save PNG" Click="OnSavePng" MinWidth="90" Background="#3A4250" Foreground="White"/>
        <Button Content="Save .mmd" Click="OnSaveMmd" MinWidth="90" Background="#3A4250" Foreground="White"/>
        <Button Content="Save .md" Click="OnSaveMd" MinWidth="90" Background="#3A4250" Foreground="White"/>
        <Button Content="Copy Mermaid" Click="OnCopyMermaid" MinWidth="90" Background="#3A4250" Foreground="White"/>
        <Button Content="Open Live Editor" Click="OnOpenLiveEditor" MinWidth="90" Background="#3A4250" Foreground="White"/>
      </StackPanel>
    </Grid>

    <!-- Right Splitter -->
    <GridSplitter Grid.Column="3" Grid.Row="0" Background="#D0D0D0" Width="1"/>

    <!-- Inspector Panel — switches between Analyze Mode and Design Mode states -->
    <ScrollViewer Grid.Column="4" Grid.Row="0" Background="#F5F5F5">
      <Grid x:Name="InspectorPanel" RowDefinitions="Auto">

        <!-- Analyze Mode inspector — shows selected node info, members, relations -->
        <StackPanel x:Name="AnalyzeInspectorState" IsVisible="True" Margin="8">
          <TextBlock Text="Inspector" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
          <TextBlock x:Name="AnalyzeInspectorTitle" Text="No node selected" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" TextWrapping="Wrap"/>
          <TextBlock x:Name="AnalyzeInspectorKind" Text="" Margin="0,2" FontSize="11" Opacity="0.7"/>
          <TextBlock x:Name="AnalyzeInspectorFile" Text="" Margin="0,2" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
          <Button Content="Open in Explorer" Click="OnOpenInExplorer" Margin="0,4,0,8" MinWidth="100" Foreground="White"/>
          <TextBlock Text="Members" FontWeight="SemiBold" Margin="0,4,0,4"/>
          <ItemsControl x:Name="AnalyzeInspectorMembers">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="x:String">
                <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas,monospace" Margin="0,1" TextWrapping="Wrap"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="Outgoing" FontWeight="SemiBold" Margin="0,8,0,4"/>
          <ItemsControl x:Name="AnalyzeInspectorOutgoing">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="x:String">
                <TextBlock Text="{Binding}" FontSize="11" Margin="0,1" TextWrapping="Wrap"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="Incoming" FontWeight="SemiBold" Margin="0,8,0,4"/>
          <ItemsControl x:Name="AnalyzeInspectorIncoming">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="x:String">
                <TextBlock Text="{Binding}" FontSize="11" Margin="0,1" TextWrapping="Wrap"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- State: Nothing selected — show summary + unnamed classes warning -->
        <StackPanel x:Name="InspectorNothingState" IsVisible="False" Margin="8">
          <TextBlock Text="Inspector" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
          <TextBlock Text="Design Summary" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <TextBlock x:Name="InspectorClassCountText" Text="" Margin="0,2"/>
          <TextBlock x:Name="InspectorEdgeCountText" Text="" Margin="0,2"/>
          <TextBlock x:Name="InspectorUnnamedText" Text="" Margin="0,8" Foreground="#CC6600"
                     IsVisible="False"/>
          <TextBlock Text="Click a class to edit its properties" Opacity="0.6" Margin="0,16,0,0"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <!-- State: Single class selected — show properties + members + relations -->
        <StackPanel x:Name="InspectorSingleClassState" IsVisible="False" Margin="8">
          <TextBlock Text="Class:" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
          <TextBlock x:Name="InspectorClassNameLabel" Text="" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="80"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition/><RowDefinition/><RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"/>
            <TextBox  Grid.Row="0" Grid.Column="1" x:Name="InspectorNameBox"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Kind" VerticalAlignment="Center"/>
            <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="InspectorKindCombo">
              <ComboBoxItem Content="Class"/>
              <ComboBoxItem Content="Interface"/>
              <ComboBoxItem Content="Enum"/>
              <ComboBoxItem Content="Struct"/>
              <ComboBoxItem Content="Static Class"/>
              <ComboBoxItem Content="Abstract Class"/>
            </ComboBox>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Namespace" VerticalAlignment="Center"/>
            <TextBox  Grid.Row="2" Grid.Column="1" x:Name="InspectorNamespaceBox"/>
          </Grid>

          <!-- Members -->
          <TextBlock Text="Members" FontWeight="SemiBold" Margin="0,8,0,4"/>
          <!-- Add member buttons -->
          <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,4">
            <Button Content="+Field" Click="OnInspectorAddField" MinWidth="56" FontSize="10"
                    Background="#3A4250" Foreground="White" Padding="4,2"/>
            <Button Content="+Prop" Click="OnInspectorAddProperty" MinWidth="56" FontSize="10"
                    Background="#3A4250" Foreground="White" Padding="4,2"/>
            <Button Content="+Method" Click="OnInspectorAddMethod" MinWidth="60" FontSize="10"
                    Background="#3A4250" Foreground="White" Padding="4,2"/>
            <Button Content="+Ctor" Click="OnInspectorAddConstructor" MinWidth="48" FontSize="10"
                    Background="#3A4250" Foreground="White" Padding="4,2"/>
          </StackPanel>
          <ItemsControl x:Name="InspectorMembersList">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="design:MemberRow">
                <Grid ColumnDefinitions="Auto,Auto,*,*,Auto" Margin="0,1">
                  <!-- Visibility badge — click to cycle -->
                  <Button Grid.Column="0" Content="{Binding VisibilityBadge}" MinWidth="22"
                          FontSize="10" Padding="2,0" Tag="{Binding}"
                          Click="OnInspectorCycleVisibility" Background="Transparent"
                          Foreground="{Binding VisibilityColor}"/>
                  <!-- Kind label -->
                  <TextBlock Grid.Column="1" Text="{Binding KindBadge}" FontSize="10"
                             VerticalAlignment="Center" Opacity="0.6" Margin="2,0,4,0"/>
                  <!-- Name — editable -->
                  <TextBox Grid.Column="2" Text="{Binding Name, Mode=TwoWay}" FontSize="11"
                           FontFamily="Consolas,monospace" Padding="2,0"
                           LostFocus="OnInspectorMemberNameChanged" Tag="{Binding}"/>
                  <!-- Type — editable -->
                  <TextBox Grid.Column="3" Text="{Binding TypeName, Mode=TwoWay}" FontSize="11"
                           FontFamily="Consolas,monospace" Padding="2,0" Opacity="0.8"
                           LostFocus="OnInspectorMemberTypeChanged" Tag="{Binding}"/>
                  <!-- Delete -->
                  <Button Grid.Column="4" Content="×" MinWidth="24" Padding="4,0"
                          Tag="{Binding}" Click="OnInspectorDeleteMember"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Outgoing relations -->
          <TextBlock Text="Outgoing" FontWeight="SemiBold" Margin="0,8,0,4"/>
          <ItemsControl x:Name="InspectorOutgoingList">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="design:EdgeRow">
                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,1">
                  <TextBlock Grid.Column="0" Text="{Binding DisplayText}" FontSize="11"/>
                  <ComboBox Grid.Column="1" SelectedValue="{Binding Kind, Mode=TwoWay}"
                            SelectionChanged="OnInspectorEdgeKindChanged" MinWidth="100">
                    <ComboBoxItem Content="Association"/>
                    <ComboBoxItem Content="Inheritance"/>
                    <ComboBoxItem Content="Implements"/>
                  </ComboBox>
                  <Button Grid.Column="2" Content="→" Click="OnInspectorJumpToClass" MinWidth="24"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Incoming relations -->
          <TextBlock Text="Incoming" FontWeight="SemiBold" Margin="0,8,0,4"/>
          <ItemsControl x:Name="InspectorIncomingList">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="design:EdgeRow">
                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,1">
                  <TextBlock Grid.Column="0" Text="{Binding DisplayText}" FontSize="11"/>
                  <ComboBox Grid.Column="1" SelectedValue="{Binding Kind, Mode=TwoWay}"
                            SelectionChanged="OnInspectorEdgeKindChanged" MinWidth="100">
                    <ComboBoxItem Content="Association"/>
                    <ComboBoxItem Content="Inheritance"/>
                    <ComboBoxItem Content="Implements"/>
                  </ComboBox>
                  <Button Grid.Column="2" Content="→" Click="OnInspectorJumpToClass" MinWidth="24"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- State: Multi-select — show bulk operations (gated on GAP-2) -->
        <StackPanel x:Name="InspectorMultiSelectState" IsVisible="False" Margin="8">
          <TextBlock Text="Multi-Select" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
          <TextBlock x:Name="InspectorMultiSelectCountText" Text="" Margin="0,0,0,8"/>
          <Button Content="Delete All" Click="OnInspectorMultiDelete" Margin="0,4"/>
          <TextBlock Text="Selected:" FontWeight="SemiBold" Margin="0,12,0,4"/>
          <ItemsControl x:Name="InspectorMultiSelectList">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="design:DesignClass">
                <TextBlock Text="{Binding Name}" Margin="4,1" FontSize="11"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Grid>
    </ScrollViewer>

    <!-- Status Bar -->
    <Border Grid.ColumnSpan="5" Grid.Row="1" Background="#2A2E34" Padding="8,3" BorderBrush="#3A4250" BorderThickness="0,1,0,0">
      <TextBlock x:Name="StatusBarText" Text="Ready" FontSize="11" Foreground="#889098"/>
    </Border>
  </Grid>
</Window>
